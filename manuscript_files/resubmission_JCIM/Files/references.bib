@article{prabhakar_elucidation_2005,
	title = {Elucidation of the mechanism of selenoprotein glutathione peroxidase ({GPx})-catalyzed hydrogen peroxide reduction by two glutathione molecules: a density functional study},
	volume = {44},
	issn = {0006-2960},
	shorttitle = {Elucidation of the mechanism of selenoprotein glutathione peroxidase ({GPx})-catalyzed hydrogen peroxide reduction by two glutathione molecules},
	doi = {10.1021/bi050815q},
	abstract = {The mechanism of the hydrogen peroxide reduction by two molecules of glutathione catalyzed by the selenoprotein glutatione peroxidase (GPx) has been computationally studied. It has been shown that the first elementary reaction of this process, (E-SeH) + H(2)O(2) --{\textgreater} (E-SeOH) + H(2)O (1), proceeds via a stepwise pathway with the overall barrier of 17.1 kcal/mol, which is in good agreement with the experimental barrier of 14.9 kcal/mol. During reaction 1, the Gln83 residue has been found to play a key role as a proton acceptor, which is consistent with experiments. The second elementary reaction, (E-SeOH) + GSH --{\textgreater} (E-Se-SG) + HOH (2), proceeds with the barrier of 17.9 kcal/mol. The last elementary reaction, (E-Se-SG) + GSH --{\textgreater} (E-SeH) + GS-SG (3), is initiated with the coordination of the second glutathione molecule. The calculations clearly suggest that the amide backbone of the Gly50 residue directly participates in this reaction and the presence of two water molecules is absolutely vital for the reaction to occur. This reaction proceeds with the barrier of 21.5 kcal/mol and is suggested to be a rate-determining step of the entire GPx-catalyzed reaction H(2)O(2) + 2GSH --{\textgreater} GS-SG + 2H(2)O. The results discussed in the present study provide intricate details of every step of the catalytic mechanism of the GPx enzyme and are in good general agreement with experimental findings and suggestions.},
	language = {eng},
	number = {35},
	journal = {Biochemistry},
	author = {Prabhakar, Rajeev and Vreven, Thom and Morokuma, Keiji and Musaev, Djamaladdin G.},
	month = sep,
	year = {2005},
	pmid = {16128588},
	keywords = {Glutathione, Glutathione Peroxidase, Oxidation-Reduction, Models, Chemical, Catalysis, Quantum Theory, Disulfides, Hydrogen Peroxide, Selenium Compounds},
	pages = {11864--11871},
}

