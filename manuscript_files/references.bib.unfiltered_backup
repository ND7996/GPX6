	number = {7},
	journal = {PloS one},
	author = {Endres, Lauren and Begley, Ulrike and Clark, Ryan and Gu, Chen and Dziergowska, Agnieszka and Małkiewicz, Andrzej and Melendez, J. Andres and Dedon, Peter C. and Begley, Thomas J.},
