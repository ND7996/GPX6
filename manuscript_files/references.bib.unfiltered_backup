	keywords = {glutathione peroxidase, oxidative stress, Oxidative stress, Glutathione peroxidase, Inflammation, Iron Death, Redox balance, inflammation, iron death, redox balance},
	pages = {1147414},
	annote = {Contents1 Introduction2 GPX family and oxidative stress2.1 GPX12.2 GPX22.3 GPX32.4 GPX42.5 GPX52.6 GPX62.7 GPX72.8 GPX83 Conclusion4 ProspectAuthor contributionsFundingConflict of interestPublisher’s noteReferences},
